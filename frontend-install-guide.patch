@@ -20,6 +26,13 @@ const els = {
   chatLength: document.getElementById("chat-length"),
   customInstructions: document.getElementById("custom-instructions"),
   faqs: document.getElementById("faqs"),
+  testChatLink: document.getElementById("test-chat-link"),
+  embedCode: document.getElementById("embed-code"),
+  copyEmbedBtn: document.getElementById("copy-embed-btn"),
+  openTestChatBtn: document.getElementById("open-test-chat-btn"),
+  openGuideBtn: document.getElementById("open-guide-btn"),
+  downloadGuideBtn: document.getElementById("download-guide-btn"),
+  installStatus: document.getElementById("install-status"),
 };
 
 function getToken() {
@@ -182,8 +195,86 @@ function appendText(parent, text, className) {
 function renderBusinessName(data) {
   const business = data?.business || data?.business_info || data?.businesses?.[0] || data || {};
   const name = getFirstValue(business, ["name", "business_name", "businessName", "folder_name"]);
+  const folderName = getFirstValue(business, ["folder_name", "business_id", "id"]);
+
+  state.businessName = name || "";
+  state.businessFolder = folderName || "";
 
   els.businessName.textContent = name ? `Business: ${name}` : "Business dashboard";
+  renderInstallSection();
+}
+
+function buildEmbedCode(businessFolder) {
+  return `<!-- Rowe AI Chatbot -->
+<script
+  src="${FRONTEND_BASE}/widget.js"
+  data-business="${businessFolder}"
+></script>`;
+}
+
+function buildTestChatUrl(businessFolder) {
+  return `${FRONTEND_BASE}/chat.html?b=${encodeURIComponent(businessFolder)}`;
+}
+
+function buildInstallGuideUrl() {
+  const params = new URLSearchParams();
+  if (state.businessFolder) {
+    params.set("b", state.businessFolder);
+  }
+  if (state.businessName) {
+    params.set("name", state.businessName);
+  }
+  const query = params.toString();
+  return `${FRONTEND_BASE}/install-guide.html${query ? `?${query}` : ""}`;
+}
+
+function renderInstallSection() {
+  if (!state.businessFolder) {
+    els.testChatLink.value = "";
+    els.embedCode.textContent = "Your embed code will appear here after your business loads.";
+    return;
+  }
+
+  els.testChatLink.value = buildTestChatUrl(state.businessFolder);
+  els.embedCode.textContent = buildEmbedCode(state.businessFolder);
+}
+
+async function copyEmbedCode() {
+  if (!state.businessFolder) {
+    setStatus(els.installStatus, "Business details are still loading.", "error");
+    return;
+  }
+
+  try {
+    await navigator.clipboard.writeText(buildEmbedCode(state.businessFolder));
+    setStatus(els.installStatus, "Embed code copied to clipboard.", "success");
+  } catch (err) {
+    console.error(err);
+    setStatus(els.installStatus, "Unable to copy automatically. Select the code and copy it manually.", "error");
+  }
+}
+
+function openTestChat() {
+  if (!state.businessFolder) {
+    setStatus(els.installStatus, "Business details are still loading.", "error");
+    return;
+  }
+
+  window.open(buildTestChatUrl(state.businessFolder), "_blank", "noopener");
+}
+
+function openInstallGuide() {
+  window.open(buildInstallGuideUrl(), "_blank", "noopener");
+}
+
+function downloadInstallGuidePdf() {
+  const guideWindow = window.open(buildInstallGuideUrl(), "_blank", "noopener");
+  if (!guideWindow) {
+    setStatus(els.installStatus, "Allow pop-ups, then try Download PDF Guide again.", "error");
+    return;
+  }
+
+  setStatus(els.installStatus, "In the guide tab, click Download / Print PDF and choose Save as PDF.", "success");
 }
 
 function renderAnalytics(data) {
@@ -546,6 +637,10 @@ document.addEventListener("DOMContentLoaded", () => {
   els.refreshBtn.addEventListener("click", reloadDashboard);
   els.settingsForm.addEventListener("submit", saveSettings);
   els.passwordForm.addEventListener("submit", changePassword);
+  els.copyEmbedBtn.addEventListener("click", copyEmbedCode);
+  els.openTestChatBtn.addEventListener("click", openTestChat);
+  els.openGuideBtn.addEventListener("click", openInstallGuide);
+  els.downloadGuideBtn.addEventListener("click", downloadInstallGuidePdf);
 
   reloadDashboard();
 });
